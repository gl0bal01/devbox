# services/traefik/.env.example
#
# Documentation aid — committed to source control so contributors can see
# which variables are required. This file is NOT consumed at runtime.
#
# At install time, setup.sh renders .env.template → .env using values from
# ~/.config/devbox/ovh.env (per ADR-0005). The rendered .env is git-ignored.
#
# This file is only relevant in HTTPS mode (ENABLE_HTTPS=true). In HTTP-only
# mode, Traefik does not require OVH credentials.
#
# OVH DNS-01 challenge credentials — obtain from https://api.ovh.com/createToken
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=replace-with-ovh-app-key
OVH_APPLICATION_SECRET=replace-with-ovh-app-secret
OVH_CONSUMER_KEY=replace-with-ovh-consumer-key
