# services/ollama-openwebui/.env.example
#
# Documentation aid — committed to source control so contributors can see
# which variables are required. This file is NOT consumed at runtime.
#
# At install time, setup.sh renders .env.template → .env. The rendered .env
# is git-ignored. WEBUI_SECRET_KEY is auto-generated by setup.sh if left
# empty or not provided.
#
WEBUI_SECRET_KEY=replace-with-32-char-random-secret
ENABLE_SIGNUP=false
