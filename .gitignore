# ============================================================================
# DevBox v1.0.0 .gitignore
#
# Principle: track sources, never secrets or runtime data.
# ============================================================================

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# ============================================================================
# Secrets — NEVER commit
# ============================================================================
# Per-service rendered .env files (the .env.template files ARE tracked)
services/**/.env
services/**/.env.local
**/.env.local
**/.env.*.local

# Top-level env files
.env
.envrc

# VPN configs
*.ovpn

# Cryptographic material
*.pem
*.key
*.crt
*.p12
acme.json
services/**/letsencrypt/

# Generic secrets dirs
secrets/
credentials/
.secrets/
**/.secrets/

# Operator-provided OVH credentials (HTTPS mode) — lives in ~/.config/devbox/,
# but defense-in-depth in case anyone drops a copy into the repo.
ovh.env
**/ovh.env

# ============================================================================
# Runtime data — generated, not tracked
# ============================================================================
# Persistent service volumes
services/**/*-data/
services/**/ollama-data/
services/**/openwebui-data/
services/**/exegol-workspace/
data/

# Traefik logs
services/**/logs/
services/**/traefik-logs/

# Pre-install backup snapshots (setup.sh --dry-run output, etc.)
*.devbox-backup.*
*.backup.*

# Local build/test artifacts
.omc/
.wolf/
.claude/
.cache/

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# Tests and local tooling
# ============================================================================
# Bats tempdirs (tests/unit/ sources tracked, not test runs)
tests/tmp/
tests/.bats.tmp/

# Coverage and trace output
coverage/
*.trace

# ============================================================================
# CI / release artifacts (generated by weekly-rebuild.yml, not committed)
# ============================================================================
devbox.tar
devbox.tar.sha256
devbox.tar.sig
devbox.tar.pem
devbox.tar.intoto.jsonl
sbom.cdx.json

# ============================================================================
# Image digest lockfiles ARE committed (see ARCHITECTURE.md — Image Pinning).
# Explicit negation in case a parent pattern ever matches.
# ============================================================================
!services/**/docker-compose.lock.yml

# ============================================================================
# Install marker is generated by setup.sh at install time (~/docker/lib/),
# never tracked. Defense-in-depth ignore.
# ============================================================================
**/.devbox-marker
.devbox-credentials
.devbox-credentials.gpg
